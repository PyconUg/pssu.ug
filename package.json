{
  "name": "pssu-ug",
  "version": "0.1.0",
  "private": true,
  "description": "Python Software Society of Uganda website",
  "scripts": {
    "tailwind": "npx @tailwindcss/cli -i ./static/css/main.css -o ./static/vendor/main.css",
    "tailwind-w": "npx @tailwindcss/cli -i ./static/css/main.css -o ./static/vendor/main.css --watch",
    "build-css": "npm run tailwind",
    "watch-css": "npm run tailwind-w"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.0.5",
    "tailwindcss": "^4.0.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
